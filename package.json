{
  "name": "storemeta",
  "version": "0.2.0",
  "description": "Store App Store Connect and Google Play metadata and screenshots as code.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "storemeta": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "pretest": "npm run build",
    "test": "vitest run",
    "precoverage": "npm run build",
    "coverage": "vitest run --coverage",
    "verify:release": "node ./scripts/verify-release.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sezaienesyildizhan/storemeta.git"
  },
  "homepage": "https://github.com/sezaienesyildizhan/storemeta#readme",
  "bugs": {
    "url": "https://github.com/sezaienesyildizhan/storemeta/issues"
  },
  "keywords": [
    "cli",
    "app-store",
    "app-store-connect",
    "android-publisher",
    "google-play",
    "ios",
    "android",
    "metadata",
    "screenshots",
    "release-automation",
    "store-listing"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "google-auth-library": "^10.6.2",
    "jose": "^6.2.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
